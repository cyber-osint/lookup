<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>Simple-Peer P2P 파일 전송</title>
    <style>
        body { font-family: sans-serif; padding: 20px; line-height: 1.6; }
        textarea { width: 100%; height: 100px; margin-bottom: 10px; }
        .box { border: 1px solid #ccc; padding: 15px; margin-bottom: 20px; border-radius: 8px; }
        #status { font-weight: bold; color: blue; }
    </style>
</head>
<body>

    <h2>Simple-Peer 파일 전송 데모</h2>
    <div id="status">상태: 연결 대기 중...</div>

    <div class="box">
        <h3>1. 연결 설정 (시그널링)</h3>
        <p>A(발신자)는 'Init' 버튼을 누르고 생성된 코드를 B에게 보내세요.</p>
        <button id="init">발신자(Initiator)로 시작</button>
        <textarea id="mySignal" placeholder="나의 시그널 데이터가 여기에 표시됩니다." readonly></textarea>
        
        <p>상대방의 시그널 데이터를 아래에 붙여넣고 '연결'을 누르세요.</p>
        <textarea id="otherSignal" placeholder="상대방의 시그널 데이터를 붙여넣으세요."></textarea>
        <button id="connect">상대방과 연결</button>
    </div>

    <div class="box">
        <h3>2. 파일 전송</h3>
        <input type="file" id="fileInput" disabled>
        <p id="downloadLink"></p>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/simple-peer/9.11.1/simplepeer.min.js"></script>

    <script>
        const status = document.getElementById('status');
        const mySignal = document.getElementById('mySignal');
        const otherSignal = document.getElementById('otherSignal');
        const fileInput = document.getElementById('fileInput');
        const downloadLink = document.getElementById('downloadLink');

        let peer = null;

        // Peer 초기화 함수
        function initPeer(initiator) {
            peer = new SimplePeer({
                initiator: initiator,
                trickle: false // 간단한 테스트를 위해 ICE Candidate를 하나로 합침
            });

            // 시그널 데이터가 생성되었을 때
            peer.on('signal', data => {
                mySignal.value = JSON.stringify(data);
            });

            // 연결이 완료되었을 때
            peer.on('connect', () => {
                status.innerText = '상태: 연결됨! 파일을 보낼 수 있습니다.';
                fileInput.disabled = false;
            });

            // 데이터를 받았을 때 (파일 수신)
            let receivedChunks = [];
            peer.on('data', data => {
                // simple-peer는 데이터를 Buffer/Uint8Array로 전달함
                receivedChunks.push(data);
                
                // 여기서는 간단하게 파일 전송 완료를 감지하는 로직이 필요하지만
                // 데모를 위해 버튼 등으로 처리하거나 고정된 크기를 기다릴 수 있습니다.
                // 이 예제는 단일 청크 전송을 가정하거나 간단한 Blob 변환을 보여줍니다.
                const blob = new Blob(receivedChunks);
                const url = URL.createObjectURL(blob);
                downloadLink.innerHTML = `<a href="${url}" download="received_file">파일 다운로드 받기</a>`;
            });
        }

        // 버튼 이벤트
        document.getElementById('init').onclick = () => initPeer(true);
        document.getElementById('connect').onclick = () => {
            const data = JSON.parse(otherSignal.value);
            if (!peer) initPeer(false);
            peer.signal(data);
        };

        // 파일 전송 이벤트
        fileInput.onchange = (e) => {
            const file = e.target.files[0];
            const reader = new FileReader();
            reader.onload = () => {
                peer.send(reader.result); // 파일 데이터를 바이너리로 전송
                status.innerText = '상태: 파일 전송 완료!';
            };
            reader.readAsArrayBuffer(file);
        };
    </script>
</body>
</html>
